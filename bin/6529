#!/usr/bin/env bash

set -euo pipefail

export COREPACK_HOME="${COREPACK_HOME:-${HOME:-${TMPDIR:-/tmp}}/.cache/6529-corepack}"
export COREPACK_ENABLE_DOWNLOAD_PROMPT="0"
export SEIZE_6529_COMMAND="1"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

command_name="${1:-}"

if [[ "$command_name" == "--help" || "$command_name" == "-h" ]]; then
  command_name=""
fi

if [[ -z "$command_name" ]]; then
  cat <<'EOF'
Usage:
  6529 <command> [args...]

Common commands:
  6529 bootstrap       -> enable the repo-scoped 6529 command for future shells
  6529 install         -> secure pnpm install for root + renderer
  6529 i               -> secure pnpm install for root + renderer
  6529 install:frozen  -> frozen secure install for root + renderer
  6529 ci              -> frozen secure install for root + renderer
  6529 install:prod    -> prod secure install for root + renderer
  6529 update          -> show pnpm audit findings
  6529 update:fix      -> sfw pnpm audit --fix
  6529 update:all      -> sfw pnpm update
  6529 audit-deps      -> show renderer pnpm audit findings
  6529 pull-web        -> pull the frontend subtree into renderer/
  6529 run dev         -> run the Electron app in dev mode
  6529 run build       -> build renderer + Electron app
  6529 run deps        -> install all dependencies

Anything else is forwarded to pnpm unchanged.
EOF
  exit 1
fi

shift

case "$command_name" in
  bootstrap)
    exec bash "$REPO_ROOT/scripts/bootstrap-6529-command.sh" "$@"
    ;;
esac

clean_path=""
IFS=':' read -r -a path_parts <<< "${PATH:-}"
for part in "${path_parts[@]}"; do
  if [[ -z "$part" || "$part" == "$SCRIPT_DIR" ]]; then
    continue
  fi
  if [[ -z "$clean_path" ]]; then
    clean_path="$part"
  else
    clean_path="${clean_path}:$part"
  fi
done

REAL_PNPM="$(PATH="$clean_path" command -v pnpm || true)"

if [[ -z "$REAL_PNPM" ]]; then
  echo "pnpm is not available. Activate the repo-pinned pnpm with Corepack first." >&2
  exit 1
fi

cd "$REPO_ROOT"

case "$command_name" in
  dev|build)
    echo "Use \`6529 run $command_name\` for package.json scripts." >&2
    exit 1
    ;;
  i)
    if [[ "$#" -gt 0 ]]; then
      echo "Use \`pnpm add <package>\` only after updating the root wrapper for add flows." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure "$@"
    ;;
  install)
    if [[ "$#" -gt 0 ]]; then
      echo "Use \`pnpm add <package>\` only after updating the root wrapper for add flows." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure "$@"
    ;;
  ci)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 ci\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:frozen "$@"
    ;;
  install:frozen)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 install:frozen\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:frozen "$@"
    ;;
  install:prod)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 install:prod\` does not accept package arguments." >&2
      exit 1
    fi
    exec "$REAL_PNPM" run install:secure:prod "$@"
    ;;
  update)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 update\` shows audit findings and does not accept package arguments." >&2
      echo "Use \`6529 update:fix\` for pnpm audit --fix or \`6529 update:all [package...]\` for intentional pnpm updates." >&2
      exit 1
    fi
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" audit
    ;;
  update:fix)
    if [[ "$#" -gt 0 ]]; then
      echo "\`6529 update:fix\` does not accept package arguments." >&2
      exit 1
    fi
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" audit --fix
    ;;
  update:all)
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    exec node "$REPO_ROOT/scripts/run-secure-pnpm.cjs" update "$@"
    ;;
  audit-deps)
    node "$REPO_ROOT/scripts/assert-no-package-lock.cjs"
    cd "$REPO_ROOT/renderer"
    exec ./bin/pnpm audit "$@"
    ;;
  deps)
    exec "$REAL_PNPM" run deps "$@"
    ;;
  pull-web)
    exec "$REAL_PNPM" run pull-web "$@"
    ;;
  run)
    if [[ "${1:-}" == "dev" ]] && {
      [[ -n "${REVIEWBOT_RESPONSIVENESS_OUTPUT_DIR:-}" ]] ||
        [[ "${PORT_SEARCH_LIMIT:-}" == "1" &&
          "${BASE_ENDPOINT:-}" == "http://127.0.0.1:${PORT:-}" &&
          "${API_ENDPOINT:-}" == "https://api.6529.io" &&
          "${WS_ENDPOINT:-}" == "wss://ws.6529.io" &&
          "${ASSETS_FROM_S3:-}" == "true" ]]
    }; then
      shift
      "$REAL_PNPM" run build-next-config
      cd "$REPO_ROOT/renderer"
      exec "$REAL_PNPM" run dev "$@"
    fi
    exec "$REAL_PNPM" run "$@"
    ;;
  exec)
    exec "$REAL_PNPM" exec "$@"
    ;;
  *)
    exec "$REAL_PNPM" "$command_name" "$@"
    ;;
esac
